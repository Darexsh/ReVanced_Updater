<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/headerBoxFillColor"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/boxStrokeColor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingTop="14dp"
        android:paddingEnd="15dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvDeveloperTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/developer_mode_title"
            android:textColor="@color/btnTextColor"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeveloperBrandLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/developer_emulated_brand_label"
            android:textColor="@color/btnTextColor"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerDeveloperBrand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvDeveloperArchLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/developer_emulated_arch_label"
            android:textColor="@color/btnTextColor"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerDeveloperArch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="330dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/terminal_panel_background"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvDeveloperDiagnosticsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="2dp"
                android:fontFamily="monospace"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeveloperClose"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/btnTextColor"
                app:cornerRadius="12dp"
                app:strokeColor="@color/boxStrokeColor"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeveloperCheckUpdates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/check_updates"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#4A4F5E"
                app:cornerRadius="12dp"
                app:strokeColor="#6A7285"
                app:strokeWidth="1dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
