<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/headerBoxFillColor"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/boxStrokeColor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingTop="14dp"
        android:paddingEnd="15dp"
        android:paddingBottom="14dp">

            <TextView
                android:id="@+id/tvAppActionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/btnTextColor"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAppActionsMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/btnTextColor"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUninstallReinstall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/uninstall_reinstall"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#4A4F5E"
                app:cornerRadius="12dp"
                app:strokeColor="#6A7285"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUninstallOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/uninstall_only"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#313847"
                app:cornerRadius="12dp"
                app:strokeColor="#515A6B"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActionCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/btnTextColor"
                app:cornerRadius="12dp"
                app:strokeColor="@color/boxStrokeColor" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
